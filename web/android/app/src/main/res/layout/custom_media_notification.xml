<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="96dp"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/notification_artwork"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/notification_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spatial X 8D"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/notification_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Background Playback"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/notification_repeat"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_popup_sync"
                android:contentDescription="Repeat"
                android:scaleType="fitCenter"
                android:padding="10dp"
                android:focusable="false"
                android:clickable="true" />

            <ImageButton
                android:id="@+id/notification_prev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Previous"
                android:scaleType="fitCenter"
                android:padding="10dp"
                android:focusable="false"
                android:clickable="true" />

            <ImageButton
                android:id="@+id/notification_play_pause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_pause"
                android:contentDescription="Play/Pause"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:focusable="false"
                android:clickable="true" />

            <ImageButton
                android:id="@+id/notification_next"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="Next"
                android:scaleType="fitCenter"
                android:padding="10dp"
                android:focusable="false"
                android:clickable="true" />
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/notification_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#7C3AED"
        android:progressBackgroundTint="#444444" />
</LinearLayout>
